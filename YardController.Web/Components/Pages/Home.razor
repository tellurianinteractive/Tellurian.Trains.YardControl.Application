@page "/"
@page "/{Station}"
@rendermode InteractiveServer
@using YardController.Web.Services
@using YardController.Web.Resources
@using Tellurian.Trains.YardController.Model
@using Tellurian.Trains.YardController.Model.Control
@inject IYardDataService YardDataService
@inject IYardController YardController
@inject IBufferedKeyReader KeyReader
@inject KeyboardCaptureService KeyboardCapture
@inject NavigationManager Navigation
@implements IAsyncDisposable

<PageTitle>@(_labelTranslator.Translate(_topology.Name, System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName))</PageTitle>

<div class="yard-container">
    <div class="emergency-bar">
        <button class="emergency-button" @onclick="SetAllSignalsRedAsync">@Messages.AllSignalsStop</button>
    </div>
    <YardView Topology="_topology" StationName="@_stationName" CellSize="40" ShowGrid="_showGrid" IsInverted="_invertView" LabelTranslator="_labelTranslator" />

    <footer>
        <label>
            <input type="checkbox" @bind="_showGrid" /> @Messages.ShowGrid
        </label>
        <label>
            <input type="checkbox" @bind="_invertView" /> @Messages.InvertView
        </label>
        <span class="hint">@Messages.EditDataFilesHint</span>
        <span class="spacer"></span>
        <button class="footer-button" @onclick="QueryPointStatesAsync" disabled="@_isBusy">@Messages.QueryPointStates</button>
        <button class="footer-button" @onclick="ResetAllPointsAsync">@Messages.ResetAllPoints</button>
        <LanguageSelector />
    </footer>
</div>

<style>
    .yard-container {
        display: flex;
        flex-direction: column;
        height: 100vh;
        background: #111;
        color: #ccc;
        overflow: hidden;
    }

    .emergency-bar {
        padding: 8px 20px;
        display: flex;
        justify-content: center;
    }

    .emergency-button {
        padding: 8px 24px;
        background: #cc0000;
        color: white;
        border: 2px solid #ff3333;
        border-radius: 6px;
        cursor: pointer;
        font-size: 1rem;
        font-weight: bold;
        letter-spacing: 0.5px;
    }

    .emergency-button:hover:not(:disabled) {
        background: #ee0000;
    }

    .emergency-button:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .yard-view {
        flex: 1;
        width: 100%;
        min-height: 0;
    }

    footer {
        padding: 10px 20px;
        display: flex;
        align-items: center;
        gap: 20px;
        font-size: 0.9rem;
    }

    footer label {
        display: flex;
        align-items: center;
        gap: 5px;
        cursor: pointer;
    }

    footer .hint {
        color: #666;
        font-style: italic;
    }

    footer .spacer {
        flex: 1;
    }

    footer .footer-button {
        padding: 4px 12px;
        background: #333;
        color: #ccc;
        border: 1px solid #555;
        border-radius: 4px;
        cursor: pointer;
        font-size: 0.85rem;
    }

    footer .footer-button:hover:not(:disabled) {
        background: #444;
    }

    footer .footer-button:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
</style>

@code {
    [Parameter]
    public string? Station { get; set; }

    private YardTopology _topology = YardTopology.Empty;
    private LabelTranslator _labelTranslator = new();
    private bool _showGrid = true;
    private bool _invertView;
    private bool _isBusy;

    private string _stationName = "";

    protected override Task OnInitializedAsync()
    {
        _stationName = Station ?? "";
        if (!string.IsNullOrEmpty(_stationName))
        {
            if (!YardDataService.AvailableStations.Any(s => s.Equals(_stationName, StringComparison.OrdinalIgnoreCase)))
            {
                Navigation.NavigateTo("/", replace: true);
                return Task.CompletedTask;
            }
            var data = YardDataService.GetStationData(_stationName);
            if (data is not null)
            {
                _topology = data.Topology;
                _labelTranslator = data.LabelTranslator;
            }
        }
        else
        {
            // Default station (first configured)
            _stationName = YardDataService.CurrentStationName;
            var data = YardDataService.GetStationData(_stationName);
            if (data is not null)
            {
                _topology = data.Topology;
                _labelTranslator = data.LabelTranslator;
            }
        }
        YardDataService.DataChanged += OnDataChanged;
        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            KeyboardCapture.StationName = _stationName;
            await KeyboardCapture.InitializeAsync();
        }
    }

    private void OnDataChanged(DataChangedEventArgs args)
    {
        if (!args.StationName.Equals(_stationName, StringComparison.OrdinalIgnoreCase))
            return;

        _topology = args.Topology;
        var data = YardDataService.GetStationData(_stationName);
        if (data is not null)
            _labelTranslator = data.LabelTranslator;
        InvokeAsync(StateHasChanged);
    }

    private async Task QueryPointStatesAsync()
    {
        _isBusy = true;
        try
        {
            var data = YardDataService.GetStationData(_stationName);
            if (data is null) return;

            var addresses = data.Points
                .Where(p => !p.IsAddressOnly)
                .SelectMany(p => p.StraightAddresses.Concat(p.DivergingAddresses))
                .Select(Math.Abs)
                .Distinct()
                .Order();

            foreach (var address in addresses)
            {
                await YardController.SendPointStateRequestAsync(address, CancellationToken.None);
                await Task.Delay(100);
            }
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void ResetAllPointsAsync()
    {
        EnqueueCommand("==");
    }

    private void SetAllSignalsRedAsync()
    {
        EnqueueCommand("**");
    }

    private void EnqueueCommand(string command)
    {
        var keys = command.Select(c => new ConsoleKeyInfo(c, default, false, false, false));
        KeyReader.EnqueueKeys(keys, _stationName);
    }

    public async ValueTask DisposeAsync()
    {
        YardDataService.DataChanged -= OnDataChanged;
        await KeyboardCapture.DisposeAsync();
    }
}
